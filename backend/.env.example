# RAG 知识问答系统 - 环境变量配置模板
# 复制此文件为 .env 并填入实际值
# cp .env.example .env

# JWT 配置（至少 32 字符）
# 生成：openssl rand -base64 48
JWT_SECRET=change-me-generate-a-random-secret-at-least-32-chars

# MinIO（须与项目根 .env 中 MINIO_ROOT_PASSWORD 一致）
MINIO_ENDPOINT=http://127.0.0.1:9000
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=minio123456
MINIO_BUCKET=rag-docs

# 管理员引导（生产环境请设为 false）
BOOTSTRAP_ENABLED=true
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123456

# 可选：通过环境变量配置 DashScope（与 llm-local.properties 二选一即可）
# LLM_PROVIDER=qwen
# SPRING_AI_OPENAI_API_KEY=YOUR_DASHSCOPE_API_KEY
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_CHAT_MODEL=qwen-plus
